<% layout('layouts/boilerplate') %>

<!-- LOCAL FONT AWESOME -->
<link rel="stylesheet" href="/fontawesome/css/all.min.css">

<div class="dashboard-wrapper">

  <div class="dashboard-card card-box">

    <% if(username === "admin"){ %>

      <!-- ADMIN DASHBOARD -->
      <div class="admin-hero">

        <div class="admin-icon">
          <i class="fa-solid fa-shield-halved"></i>
        </div>

        <h1 class="dashboard-title">

         
          Welcome Back, Admin

        </h1>
        <p class="admin-subtitle">

          <i class="fa-solid fa-circle-info"></i>
          Manage tests, monitor students, upload flashcards,
          and control the examination portal.

        </p>

      </div>

      <div class="dashboard-actions">

        <a class="action-btn results" href="/admin">

          <i class="fa-solid fa-screwdriver-wrench"></i>
          Admin Panel

        </a>

        <a class="action-btn tests" href="/admin/results">

          <i class="fa-solid fa-chart-line"></i>
          View Results

        </a>

      </div>

    <% } else { %>

      <!-- STUDENT DASHBOARD -->

      <h2 class="dashboard-title">

        <i class="fa-solid fa-user"></i>
        Welcome <%= username %>

      </h2>

      <div class="dashboard-actions">

        <a class="action-btn results" href="/flashcards">

          <i class="fa-solid fa-book-open"></i>
          Read Flashcards

        </a>

        <a
          class="action-btn tests"
          href="/tests?username=<%= username %>"
        >

          <i class="fa-solid fa-file-pen"></i>
          Take Test

        </a>

      </div>

    <% } %>

    <a class="logout-btn" href="/logout">

      <i class="fa-solid fa-right-from-bracket"></i>
      Logout

    </a>

  </div>

</div>

<style>

/* ADMIN HERO */
.admin-hero{
  text-align:center;
  margin-bottom:2rem;
}

.admin-icon{
  width:100px;
  height:100px;
  margin:auto auto 1.5rem;
  border-radius:28px;

  background: linear-gradient(135deg,#5b7cff,#7f96ff);
  display:flex;
  align-items:center;
  justify-content:center;

  font-size:2.5rem;
  color:#fff;

  box-shadow:0 20px 40px rgba(91,124,255,.28);
}

/* SUBTITLE */
.admin-subtitle{
  max-width:500px;
  margin:auto;
  color:#9aa3bc;
  line-height:1.7;
}

/* LOGOUT */
.logout-btn{
  margin-top:1rem;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:10px;

  background: linear-gradient(135deg,#ff5b6e,#ff7382);
  color:#fff;

  padding:.95rem 1.4rem;
  border-radius:16px;
  font-weight:600;
  transition:.22s ease;
}

.logout-btn:hover{
  transform:translateY(-2px);
  box-shadow:0 12px 25px rgba(255,91,110,.24);
}

</style>