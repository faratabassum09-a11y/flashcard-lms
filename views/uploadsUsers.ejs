<% layout("layouts/boilerplate") %>

<div style="padding:40px">

  <h1>User Excel Uploads</h1>

  <br>

  <% if(files.length === 0){ %>

    <h3>No user uploads found </h3>

  <% } %>

  <% files.forEach(file => { %>

    <div style="
      padding:15px;
      margin-bottom:10px;
      border:1px solid #444;
      border-radius:10px;
    ">

      <h3><%= file %></h3>

      <a href="/uploads/users/<%= file %>" target="_blank">
        View File
      </a>

      <br><br>

      <form
        action="/delete-user-upload/<%= file %>?_method=DELETE"
        method="POST"
      >
        <button type="submit">
          Delete
        </button>
      </form>

    </div>

  <% }) %>

</div>