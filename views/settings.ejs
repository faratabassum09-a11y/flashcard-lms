
<% layout("layouts/boilerplate.ejs") %>

<div class="settings-page">

  <!-- LEFT -->
  <div class="settings-left">

    <div class="settings-card">

      <div class="settings-header">

        <div class="profile-avatar">
          <%= user.username[0].toUpperCase() %>
        </div>

        <div>
          <h1><%= user.username %></h1>
          <p>
            <%= user.username === "admin" ? "Administrator" : "Student Account" %>
          </p>
        </div>

      </div>

      <% if(user.username !== "admin"){ %>

      <!-- STATS -->
      <div class="settings-stats">

        <div class="stat-card">
          <h3>
            <i class="fa-solid fa-pen"></i>
            Tests Attempted
          </h3>

          <h1><%= totalTests %></h1>
        </div>

        <div class="stat-card">
          <h3>
            <i class="fa-solid fa-chart-line"></i>
            Total Marks
          </h3>

          <h1><%= totalMarks %></h1>
        </div>

      </div>

      <!-- RECENT RESULTS -->
      <div class="recent-results">

        <h2 class="section-title">
          <i class="fa-solid fa-clock-rotate-left"></i>
          Recent Results
        </h2>

        <% if(results.length === 0){ %>

          <p class="empty-text">
            No tests attempted yet.
          </p>

        <% } else { %>

          <% results.forEach(r => { %>

            <div class="result-item">

              <div>
                <h3>
                  <%= r.testId?.name || "Deleted Test" %>
                </h3>

                <p>
                  <%= r.testId?.subject || "No Subject" %>
                </p>

                <small>
                  <%= new Date(r.submittedAt).toLocaleDateString() %>
                </small>
              </div>

              <div class="score-badge">
                <%= r.score %>/<%= r.total %>
              </div>

            </div>

          <% }) %>

        <% } %>

      </div>

      <% } %>

    </div>

  </div>

  <!-- RIGHT -->
  <div class="settings-right">

    <div class="settings-card">

      <h2 class="section-title">
        <i class="fa-solid fa-lock"></i>
        Change Password
      </h2>

      <form action="/change-password" method="POST">

        <input
          type="password"
          name="currentPassword"
          placeholder="Current Password"
          required
        >

        <input
          type="password"
          name="newPassword"
          placeholder="New Password"
          required
        >

        <button type="submit">
          <i class="fa-solid fa-key"></i>
          Update Password
        </button>

      </form>

    </div>

  </div>

</div>

<style>

.settings-page{
  max-width:1200px;
  margin:3rem auto;
  padding:0 1.5rem;

  display:grid;
  grid-template-columns:1.2fr .8fr;
  gap:24px;
}

.settings-card{
  background:#171923;

  border:1px solid rgba(255,255,255,.06);

  border-radius:28px;

  padding:2rem;

  box-shadow:
    0 20px 40px rgba(0,0,0,.30);

  backdrop-filter:blur(12px);
}

.settings-header{
  display:flex;
  align-items:center;
  gap:18px;

  margin-bottom:2rem;
}

.profile-avatar{
  width:84px;
  height:84px;

  border-radius:50%;

  background:
    linear-gradient(
      135deg,
      #5b7cff,
      #7f96ff
    );

  display:flex;
  align-items:center;
  justify-content:center;

  color:#fff;

  font-size:2rem;
  font-weight:700;

  box-shadow:
    0 15px 30px rgba(91,124,255,.25);
}

.settings-header h1{
  color:#fff;
  margin-bottom:4px;
}

.settings-header p{
  color:#98a0b8;
}

.settings-stats{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:18px;

  margin-bottom:2rem;
}

.stat-card{
  background:#1e2230;

  border-radius:22px;

  padding:1.5rem;

  border:1px solid rgba(255,255,255,.05);

  transition:.22s ease;
}

.stat-card:hover{
  transform:translateY(-3px);

  border-color:rgba(91,124,255,.25);
}

.stat-card h3{
  color:#b7c0db;

  font-size:.95rem;

  margin-bottom:10px;

  display:flex;
  align-items:center;
  gap:10px;
}

.stat-card h1{
  color:#fff;

  font-size:2.2rem;
}

.section-title{
  color:#fff;

  margin-bottom:1.3rem;

  display:flex;
  align-items:center;
  gap:10px;
}

.result-item{
  display:flex;
  align-items:center;
  justify-content:space-between;

  gap:16px;

  background:#1e2230;

  border-radius:20px;

  padding:1rem 1.2rem;

  margin-bottom:14px;

  border:1px solid rgba(255,255,255,.04);

  transition:.22s ease;
}

.result-item:hover{
  transform:translateY(-2px);

  border-color:rgba(91,124,255,.18);
}

.result-item h3{
  color:#fff;

  margin-bottom:5px;

  font-size:1rem;
}

.result-item p{
  color:#9ba5c2;

  font-size:.88rem;

  margin-bottom:4px;
}

.result-item small{
  color:#76809b;
}

.score-badge{
  min-width:72px;
  height:72px;

  border-radius:50%;

  background:
    linear-gradient(
      135deg,
      #5b7cff,
      #7f96ff
    );

  display:flex;
  align-items:center;
  justify-content:center;

  color:#fff;

  font-size:1rem;
  font-weight:700;

  box-shadow:
    0 10px 25px rgba(91,124,255,.22);
}

.empty-text{
  color:#98a0b8;
}

form{
  display:flex;
  flex-direction:column;
  gap:16px;
}

form input{
  width:100%;

  background:#1e2230;

  border:1px solid rgba(255,255,255,.06);

  border-radius:16px;

  padding:1rem;

  color:#fff;

  font-size:.95rem;

  transition:.2s ease;
}

form input:focus{
  outline:none;

  border-color:#5b7cff;

  box-shadow:
    0 0 0 4px rgba(91,124,255,.14);
}

form button{
  border:none;

  border-radius:16px;

  padding:1rem;

  background:
    linear-gradient(
      135deg,
      #5b7cff,
      #7f96ff
    );

  color:#fff;

  font-weight:600;

  cursor:pointer;

  transition:.22s ease;

  display:flex;
  align-items:center;
  justify-content:center;
  gap:10px;
}

form button:hover{
  transform:translateY(-2px);

  box-shadow:
    0 12px 28px rgba(91,124,255,.25);
}

@media(max-width:900px){

  .settings-page{
    grid-template-columns:1fr;
  }

}

@media(max-width:600px){

  .settings-stats{
    grid-template-columns:1fr;
  }

}
</style>

