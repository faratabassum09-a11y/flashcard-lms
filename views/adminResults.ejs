<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/fontawesome/css/all.min.css">

<div class="results-wrapper">

  <!-- TITLE -->
  <h1 class="mb-4 fw-bold">

    <!-- <i class="fa-solid fa-chart-line"></i> -->
    Results Dashboard

  </h1>

  <!-- NAV -->
  <nav class="mb-4 d-flex gap-2 flex-wrap">

    <a href="/admin" class="btn btn-outline-dark btn-sm">

      <!-- <i class="fa-solid fa-gauge-high"></i> -->
      Admin Panel

    </a>

    <a href="/tests" class="btn btn-outline-dark btn-sm">

      <!-- <i class="fa-solid fa-clipboard-list"></i> -->
      Tests

    </a>

    <!-- <a href="/logout" class="btn btn-outline-danger btn-sm">

      <i class="fa-solid fa-right-from-bracket"></i>
      Logout -->

    </a>

  </nav>

  <!-- SEARCH -->
  <div class="mb-4">

    <div class="input-group w-50">

      <span class="input-group-text">

        <i class="fa-solid fa-magnifying-glass"></i>

      </span>

      <input
        type="text"
        id="searchInput"
        class="form-control"
        placeholder="Search student name..."
        oninput="filterTable()"
      >

    </div>

  </div>

  <!-- EMPTY -->
  <% if (Object.keys(grouped).length === 0) { %>

    <div class="card-box p-4 text-center">

      <h5 class="text-muted">

        <i class="fa-solid fa-circle-info"></i>
        No results available yet

      </h5>

    </div>

  <% } %>

  <!-- SUBJECT LOOP -->
  <% Object.entries(grouped).forEach(([subject, tests]) => { %>

    <div class="mb-5">

      <!-- SUBJECT -->
      <h3 class="fw-bold mb-3">

        <i class="fa-solid fa-book-open"></i>
        <%= subject %>

      </h3>

      <!-- TEST LOOP -->
      <% Object.entries(tests).forEach(([testName, info]) => { %>

        <div class="card-box p-3 mb-4">

          <!-- TOP -->
<div class="d-flex justify-content-between align-items-center mb-2">

  <h5 class="mb-0">

    <i class="fa-solid fa-file-circle-question"></i>
    <%= testName %>

  </h5>

  <div class="d-flex align-items-center gap-2">

    <a
      href="/admin/results/pdf/<%= info.testId %>"
      class="btn btn-danger btn-sm"
    >
      <i class="fa-solid fa-file-pdf"></i>
      Download PDF
    </a>

    <% if (info.isEnded) { %>

      <span class="badge bg-danger">

        <i class="fa-solid fa-circle-xmark"></i>
        Ended

      </span>

    <% } else { %>

      <span class="badge bg-success">

        <i class="fa-solid fa-circle-check"></i>
        Active

      </span>

    <% } %>

  </div>

</div>

          <!-- DURATION -->
          <small class="text-muted">

            <i class="fa-solid fa-clock"></i>
            Duration: <%= info.duration %> minutes

          </small>

          <!-- TABLE -->
          <div class="table-responsive mt-3">

            <table class="table table-hover align-middle">

              <thead class="table-dark">

                <tr>

                  <th>

                    <i class="fa-solid fa-hashtag"></i>

                  </th>

                  <th>

                    <i class="fa-solid fa-user"></i>
                    Student

                  </th>

                  <th>

                    <i class="fa-solid fa-star"></i>
                    Score

                  </th>

                  <th>

                    <i class="fa-solid fa-square-root-variable"></i>
                    Out Of


                  </th>

                  <th>

                    <i class="fa-solid fa-percent"></i>
                    Percentage

                  </th>

                  <th>

                    <i class="fa-solid fa-signal"></i>
                    Status

                  </th>

                </tr>

              </thead>

              <tbody class="results-body">

                <% info.rows.forEach((row, i) => { %>

                  <%
                    const pct = row.attempted && row.total > 0
                      ? Math.round((row.score / row.total) * 100)
                      : null;
                  %>

                  <tr>

                    <!-- NUMBER -->
                    <td>

                      <%= i + 1 %>

                    </td>

                    <!-- STUDENT -->
                    <td class="student-name fw-semibold">

                      <i class="fa-solid fa-user-graduate"></i>
                      <%= row.username %>

                    </td>

                    <!-- SCORE -->
                    <td>

                      <% if (row.attempted) { %>

                        <span class="text-success fw-bold">

                          <i class="fa-solid fa-trophy"></i>
                          <%= row.score %>

                        </span>

                      <% } else { %>

                        <span class="text-muted">

                          <i class="fa-solid fa-minus"></i>

                        </span>

                      <% } %>

                    </td>

                    <!-- TOTAL -->
                    <td>

                      <% if (row.attempted) { %>

                        <i class="fa-solid fa-medal"></i>
                        <%= row.total %>

                      <% } else { %>

                        <span class="text-muted">

                          <i class="fa-solid fa-minus"></i>

                        </span>

                      <% } %>

                    </td>

                    <!-- PERCENT -->
                    <td>

                      <% if (pct !== null) { %>

                        <div class="d-flex align-items-center gap-2">

                          <span>

                            <i class="fa-solid fa-chart-simple"></i>
                            <%= pct %>%

                          </span>

                          <div
                            class="progress"
                            style="width: 100px; height: 6px;"
                          >

                            <div
                              class="progress-bar bg-success"
                              style="width: <%= pct %>%"
                            ></div>

                          </div>

                        </div>

                      <% } else { %>

                        <span class="text-muted">

                          <i class="fa-solid fa-minus"></i>

                        </span>

                      <% } %>

                    </td>

                    <!-- STATUS -->
                    <td>

                      <% if (row.attempted) { %>

                        <span class="badge bg-success">

                          <i class="fa-solid fa-check"></i>
                          Submitted

                        </span>

                      <% } else { %>

                        <span class="badge bg-secondary">

                          <i class="fa-solid fa-clock"></i>
                         NA

                        </span>

                      <% } %>

                    </td>

                  </tr>

                <% }) %>

              </tbody>

            </table>

          </div>

        </div>

      <% }) %>

    </div>

  <% }) %>

</div>

<!-- SEARCH SCRIPT -->
<script>

function filterTable() {

  const q =
    document
      .getElementById("searchInput")
      .value
      .toLowerCase();

  document
    .querySelectorAll(".results-body tr")
    .forEach(row => {

      const name =
        row
          .querySelector(".student-name")
          ?.textContent
          .toLowerCase() || "";

      row.style.display =
        name.includes(q)
          ? ""
          : "none";

    });

}

</script>